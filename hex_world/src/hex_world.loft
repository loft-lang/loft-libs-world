//
// hex_world — sparse 32x32-chunk world data model shared by TTT v5
// (lib/game_protocol/examples/v5_*) and the audience-generative-art
// demo (plans/future/36-audience-generative-art/).
//
// Renamed from `world` 2026-06-01 (LAVITION W.1) — the hex_ prefix
// disambiguates from voxel/tile/BSP "world" expectations and matches
// the planned hex_walls / hex_terrain / hex_items family.
//
// Reuses the lib/moros_map chunk addressing pattern (32-wide chunks,
// floor-division for negative coords) but with a slimmer 4-byte Cell
// (no separate Hex struct, no per-cell layer, no editor metadata).
//
// Wire layout — each Cell packs to exactly 4 bytes:
//   [c_color: u8] [c_height: u8] [c_age: u16-LE]
//
// The server holds the canonical World; the projector + phone clients
// receive binary world_snapshot / world_delta blobs (5-byte header
// `[type:u8] [session:u32-LE]` + payload).  TTT v5 reuses the same
// shape; only the colour-byte semantics differ (1 = X, 2 = O, vs.
// 1-9 = palette colours in the demo).

// ── Types ───────────────────────────────────────────────────────────

// 4-byte cell.  c_color uses the u8 typedef (integer limit(0,255)
// size(1)); c_age uses u16 (size(2)).  Storage packs to exactly 4
// bytes per cell — the projector ships them through the binary
// surface in chunk-major order.
//
// c_color = 0 means "empty" (no crystal, no TTT mark).  Both clients
// treat 0 as background; non-zero as live content.
pub struct Cell {
  c_color:  u8 not null,
  c_height: u8 not null,
  c_age:    u16 not null,
}

// 32x32 grid at chunk coords (ck_cx, ck_cz).  Index into ck_cells:
// hx * 32 + hz where hx, hz ∈ [0, 31].  Same shape as moros_map's
// Chunk minus the cy layer (this world is single-layer).
pub struct Chunk {
  ck_cx:    integer not null,
  ck_cz:    integer not null,
  ck_cells: vector<Cell>,
}

// Top-level container.  Sparse: only chunks with at least one
// non-empty cell live in `chunks`; empty chunks are removed by the
// tick loop's GC pass.  `tick` is monotonic per server lifetime.
pub struct World {
  chunks: vector<Chunk> not null,
  tick:   integer not null,
}

// ── Addressing helpers ────────────────────────────────────────────
//
// Public so packing / unpacking code in TTT v5 + plan-36 can route
// world (q, r) coordinates to the right chunk + intra-chunk slot
// without re-implementing the floor-division dance for negatives.

// floor(v / 32) — handles negative v correctly (C-style `/` rounds
// toward zero, which silently maps cell (-1, 0) to chunk 0 instead
// of chunk -1).
pub fn chunk_idx_32(v: integer) -> integer {
  vr = v % 32;
  if vr < 0 { (v - vr - 32) / 32 } else { (v - vr) / 32 }
}

// v mod 32, always in [0, 31].
pub fn hex_idx_32(v: integer) -> integer {
  vr = v % 32;
  if vr < 0 { vr + 32 } else { vr }
}

// ── Constructors ──────────────────────────────────────────────────

// Default empty cell.  All fields zero; serialises to four 0x00
// bytes on the wire.
pub fn cell_empty() -> Cell {
  Cell { c_color: 0, c_height: 0, c_age: 0 }
}

// Build a 32x32 chunk filled with empty cells at chunk coords
// (cx, cz).
pub fn build_chunk(cx: integer, cz: integer) -> Chunk {
  cells: vector<Cell> = [];
  for _ in 0..1024 { cells += [cell_empty()]; }
  Chunk { ck_cx: cx, ck_cz: cz, ck_cells: cells }
}

// New empty world, tick 0, no chunks.
pub fn world_empty() -> World {
  World { chunks: [], tick: 0 }
}

// ── Cell access ───────────────────────────────────────────────────
//
// Linear scan through `chunks` for the matching (cx, cz).  Sparse
// worlds keep `chunks` small (typically <100), so the scan is cheap
// — matches moros_map's design choice and avoids a separate
// hash-by-chunk-coord index.  If profiling shows a hot site, the
// indexed variant lives in moros_map's pattern and can be lifted
// here.

// True iff a chunk exists at the global (q, r).
pub fn has_chunk(self: World, q: integer, r: integer) -> boolean {
  cx = chunk_idx_32(q);
  cz = chunk_idx_32(r);
  for hc_c in self.chunks {
    if hc_c.ck_cx == cx && hc_c.ck_cz == cz { return true; }
  }
  false
}

// Ensure a chunk exists at the global (q, r); creates a 32x32 of
// empty cells if absent.
pub fn ensure_chunk(self: &World, q: integer, r: integer) {
  cx = chunk_idx_32(q);
  cz = chunk_idx_32(r);
  for ec_c in self.chunks {
    if ec_c.ck_cx == cx && ec_c.ck_cz == cz { return; }
  }
  self.chunks += [build_chunk(cx, cz)];
}

// Read the cell at global (q, r).  Returns `cell_empty()` when the
// chunk does not exist (sparse-world convention — empty chunks are
// implicitly all-empty).
pub fn get_cell(self: World, q: integer, r: integer) -> Cell {
  cx = chunk_idx_32(q);
  cz = chunk_idx_32(r);
  hx = hex_idx_32(q);
  hz = hex_idx_32(r);
  idx = hx * 32 + hz;
  for gc_c in self.chunks {
    if gc_c.ck_cx == cx && gc_c.ck_cz == cz {
      cells = gc_c.ck_cells;
      if idx < len(cells) { return cells[idx]; }
      return cell_empty();
    }
  }
  cell_empty()
}

// Write a cell at global (q, r).  Creates the containing chunk on
// demand; does NOT GC empty chunks (the tick loop's end-of-tick
// pass owns that).
pub fn set_cell(self: &World, q: integer, r: integer, value: Cell) {
  ensure_chunk(self, q, r);
  cx = chunk_idx_32(q);
  cz = chunk_idx_32(r);
  hx = hex_idx_32(q);
  hz = hex_idx_32(r);
  idx = hx * 32 + hz;
  for sc_c in self.chunks {
    if sc_c.ck_cx == cx && sc_c.ck_cz == cz {
      cells = sc_c.ck_cells;
      if idx < len(cells) { cells[idx] = value; }
      return;
    }
  }
}

// ── Aggregates + neighbour counting ────────────────────────────────

// Total number of non-empty cells across every chunk.
pub fn cell_count(self: World) -> integer {
  cct_total = 0;
  for cct_c in self.chunks {
    for cct_cell in cct_c.ck_cells {
      if cct_cell.c_color != 0 { cct_total += 1; }
    }
  }
  cct_total
}

// Count filled axial-hex neighbours of the cell at global (q, r).
// Returns 0..=6.  Empty centre cell is fine — neighbours are read
// independently of the centre's state.
pub fn neighbour_count(self: World, q: integer, r: integer) -> integer {
  nc_count = 0;
  if get_cell(self, q + 1, r    ).c_color != 0 { nc_count += 1; }
  if get_cell(self, q - 1, r    ).c_color != 0 { nc_count += 1; }
  if get_cell(self, q,     r + 1).c_color != 0 { nc_count += 1; }
  if get_cell(self, q,     r - 1).c_color != 0 { nc_count += 1; }
  if get_cell(self, q + 1, r - 1).c_color != 0 { nc_count += 1; }
  if get_cell(self, q - 1, r + 1).c_color != 0 { nc_count += 1; }
  nc_count
}

// ── Tick + decay ───────────────────────────────────────────────────
//
// One world step: advances `tick`, ages every non-empty cell by 1,
// then removes any cell whose `c_age` has crossed
// `effective_lifetime + decay_window` where
// `effective_lifetime = base_lifetime + neighbour_lease *
// filled_neighbour_count`.  Neighbour counts are computed against
// the PRE-TICK state — a single tick can remove a connected blob
// of cells, but the cascade (centre losing its neighbour support)
// only fires on the NEXT tick.  This keeps the simulation
// deterministic per-step and prevents one-tick complete collapse
// of large clusters.
pub fn tick_and_decay(self: &World, base_lifetime: integer,
                       neighbour_lease: integer, decay_window: integer) {
  self.tick += 1;

  // Pass 1 — decide removals using PRE-TICK state.  Two parallel
  // vectors record (q, r) pairs to flush; using parallel vectors
  // sidesteps the tuple-vector codegen path that's still fragile
  // across some loft compiler shapes.
  rm_q: vector<integer> = [];
  rm_r: vector<integer> = [];
  for tc in self.chunks {
    for thx in 0..32 {
      for thz in 0..32 {
        tidx = thx * 32 + thz;
        tcell = tc.ck_cells[tidx];
        if tcell.c_color == 0 { continue; }
        tq = tc.ck_cx * 32 + thx;
        tr = tc.ck_cz * 32 + thz;
        tnbr = neighbour_count(self, tq, tr);
        teff = base_lifetime + neighbour_lease * tnbr;
        tnew_age = tcell.c_age + 1;
        if tnew_age > 65535 { tnew_age = 65535; }
        if tnew_age >= teff + decay_window {
          rm_q += [tq];
          rm_r += [tr];
        }
      }
    }
  }

  // Pass 2 — increment c_age on every non-empty cell.  Cells
  // scheduled for removal still get their age bumped here so a
  // post-mortem peek (debugging hooks) sees a coherent number;
  // the immediate `set_cell(... cell_empty())` below clears them.
  for ic in self.chunks {
    for ihx in 0..32 {
      icells = ic.ck_cells;
      for ihz in 0..32 {
        iidx = ihx * 32 + ihz;
        if iidx < len(icells) {
          icell = icells[iidx];
          if icell.c_color == 0 { continue; }
          inew_age = icell.c_age + 1;
          if inew_age > 65535 { inew_age = 65535; }
          icells[iidx] = Cell {
            c_color:  icell.c_color,
            c_height: icell.c_height,
            c_age:    inew_age as u16,
          };
        }
      }
    }
  }

  // Pass 3 — apply removals.
  rm_n = len(rm_q);
  for rm_i in 0..rm_n {
    set_cell(self, rm_q[rm_i], rm_r[rm_i], cell_empty());
  }
}

// ── Persistence — binary snapshot save / load ──────────────────────
//
// Whole-world dump.  Single-shot full-state snapshot; the file is
// truncated on each save.  Append-only change-log support is a future
// extension that needs an "open without truncate" file primitive (see
// `doc/claude/plans/36-audience-generative-art/01-server-state.md`
// § Persistence — language-level blockers).
//
// File layout (little-endian, version 1):
//   [4B u32  : magic 0x57524C44 'WRLD']
//   [4B u32  : format version = 1]
//   [4B i32  : tick]
//   [4B u32  : chunk count N]
//   N × {
//     [4B i32: ck_cx]
//     [4B i32: ck_cz]
//     [4B u32: filled-cell count K in this chunk]
//     K × {
//       [2B u16: cell idx within chunk (0..1023)]
//       [1B u8 : c_color]
//       [1B u8 : c_height]
//       [2B u16: c_age]
//     }
//   }
//
// Costs: O(total cells) per save, ~6 bytes per filled cell + 12 bytes
// per non-empty chunk + 16 bytes header.  A 1000-cell world fits in
// ~6 KB.

WORLD_FILE_MAGIC   = 0x57524C44;       // 'WRLD'
WORLD_FILE_VERSION = 1;

// Count the filled (c_color != 0) cells in a single chunk.
fn chunk_filled_count(c: Chunk) -> integer {
  cfc_k = 0;
  for cfc_cell in c.ck_cells {
    if cfc_cell.c_color != 0 { cfc_k += 1; }
  }
  cfc_k
}

// Save the world to `path`, replacing whatever was there.
pub fn world_save(self: World, path: text) {
  // Pre-count non-empty chunks so the header is correct without a
  // second pass over `chunks` after the file is open.
  ws_n_chunks = 0;
  for ws_pc in self.chunks {
    if chunk_filled_count(ws_pc) > 0 { ws_n_chunks += 1; }
  }
  {
    f = file(path);
    f#format = LittleEndian;
    // Snapshot semantics: each save replaces the previous file.  Make
    // the truncation explicit so the sequence keeps working once `+=`
    // is append-only (rather than truncating on first reopen).
    f.set_file_size(0);
    // Explicit `as i32` casts force 4-byte writes — without them, a
    // bare `integer` value writes 8 bytes (loft stores integers as
    // i64 internally; the file API takes the storage width unless
    // overridden by a cast).  c_color/c_height/c_age are written at
    // their declared u8/u16 widths automatically because they're
    // strongly typed struct fields.
    f += (WORLD_FILE_MAGIC   as i32);
    f += (WORLD_FILE_VERSION as i32);
    f += (self.tick          as i32);
    f += (ws_n_chunks        as i32);
    for ws_c in self.chunks {
      ws_k = chunk_filled_count(ws_c);
      if ws_k == 0 { continue; }
      f += (ws_c.ck_cx as i32);
      f += (ws_c.ck_cz as i32);
      f += (ws_k       as i32);
      for ws_i in 0..1024 {
        ws_cell = ws_c.ck_cells[ws_i] ?? cell_empty();
        if ws_cell.c_color == 0 { continue; }
        f += (ws_i as u16);
        f += ws_cell.c_color as u8;
        f += ws_cell.c_height as u8;
        f += ws_cell.c_age as u16;
      }
    }
    f.sync();
  }
}

// Load the world from `path`.  Mutates `self` in place; pre-existing
// cells in `self` are left untouched unless the snapshot overwrites
// the same (q, r).  Returns the number of cells loaded.  Returns 0 if
// the file does not exist, has the wrong magic, or carries an
// unsupported version — never panics.
pub fn world_load(self: &World, path: text) -> integer {
  // `f#read as T` reads exactly T's byte width — no size argument
  // needed.  For the per-cell payload reads, the LHS-driven form
  // is even shorter: the field's declared type (`u8` / `u16`) IS the
  // width, so no `as T` at all.
  if !exists(path) { return 0; }
  f = file(path);
  f#format = LittleEndian;
  wl_magic = f#read as i32;
  if wl_magic != (WORLD_FILE_MAGIC as i32) { return 0; }
  wl_version = f#read as i32;
  if wl_version != (WORLD_FILE_VERSION as i32) { return 0; }
  self.tick = f#read as i32;
  wl_n_chunks = f#read as i32;
  wl_total = 0;
  wl_i_chunk = 0;
  while wl_i_chunk < wl_n_chunks {
    wl_cx = f#read as i32;
    wl_cz = f#read as i32;
    wl_k  = f#read as i32;
    // Ensure the target chunk exists, then locate it for direct
    // index-into-ck_cells writes.  We pass a global (q, r) inside
    // the chunk's footprint so chunk_idx_32 reproduces (wl_cx, wl_cz).
    ensure_chunk(self, wl_cx * 32, wl_cz * 32);
    for wl_target in self.chunks {
      if wl_target.ck_cx != wl_cx { continue; }
      if wl_target.ck_cz != wl_cz { continue; }
      wl_j = 0;
      wl_cells = wl_target.ck_cells;
      while wl_j < wl_k {
        wl_idx = f#read as u16;     // explicit — `wl_idx` is a local with no type hint
        wl_cell = Cell{c_color: 0, c_height: 0, c_age: 0};
        wl_cell.c_color  = f#read;   // LHS-driven: c_color is u8 → 1 byte
        wl_cell.c_height = f#read;   //             c_height is u8 → 1 byte
        wl_cell.c_age    = f#read;   //             c_age is u16 → 2 bytes
        if wl_idx < len(wl_cells) { wl_cells[wl_idx] = wl_cell; }
        wl_total += 1;
        wl_j += 1;
      }
      break;
    }
    wl_i_chunk += 1;
  }
  wl_total
}
